{
  "version": 2,
  "buildCommand": "pnpm vercel-build",
  "outputDirectory": ".",
  "functions": {
    "api/index.ts": {
      "includeFiles": "{dist/**,web-ui/dist/**,node_modules/.prisma/**,node_modules/@prisma/client/**}",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }]
}
