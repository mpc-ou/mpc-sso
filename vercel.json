{
  "version": 2,
  "outputDirectory": ".",
  "functions": {
    "api/index.ts": {
      "includeFiles": "{dist/src/**,web-ui/dist/**,node_modules/.prisma/**,node_modules/@prisma/client/**}",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }]
}
