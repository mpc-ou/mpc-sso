# ── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mpc_sso?schema=public"

# ── Server ───────────────────────────────────────────────
PORT=3000
# Public base URL of this SSO service (no trailing slash) — used in OIDC discovery,
# JWT `iss` claim, and password-reset links.
ISSUER="http://localhost:3000"
# Base URL of the (future) Admin UI — used for CORS.

# ── JWT (ES256 key pair) ─────────────────────────────────
# Generate with: pnpm keys:generate
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── Admin / Service secrets ──────────────────────────────
# Generate strong random values, e.g.: openssl rand -hex 32
ADMIN_SECRET=
SERVICE_API_KEY=
SESSION_SECRET=

# ── Google OAuth (optional — leave blank to disable "Login with Google") ─
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL="http://localhost:3000/login/google/callback"

# ── Email (SMTP) — used for password reset links ────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="noreply@mpclub.dev"

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=